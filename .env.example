# Copy this file to `.env` for local development.

# Optional for the legacy Gemini Developer API route used in local mode.
# Vertex AI mode does not require an API key.
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: move generated project state and uploaded media elsewhere.
# FMV_DATA_DIR=.fmv-data

# GenAI runtime selection:
# - `developer` uses Gemini Developer API keys locally.
# - `vertex` uses Vertex AI + Application Default Credentials.
# FMV_GENAI_BACKEND=developer
# FMV_GCP_PROJECT=your-gcp-project-id
# FMV_VERTEX_LOCATION=global
# FMV_VERTEX_MEDIA_LOCATION=us-central1

# Storage selection:
# - `local` keeps project state and media under `.fmv-data/`
# - `gcs` persists project state/media to a Google Cloud Storage bucket
# FMV_STORAGE_BACKEND=local
# FMV_GCS_BUCKET=your-fmv-studio-assets-bucket
# Optional object prefixes when FMV_STORAGE_BACKEND=gcs
# FMV_GCS_PROJECT_PREFIX=state
# FMV_GCS_MEDIA_PREFIX=projects

# Optional stage-review speech summaries
# FMV_TTS_MODEL=gemini-2.5-flash-preview-tts
# FMV_STAGE_BRIEF_VOICE=Kore

# Background pipeline execution:
# `local` keeps using in-process async jobs for local development.
# `cloud_tasks` dispatches filming jobs through Google Cloud Tasks.
# FMV_JOB_DRIVER=local

# Required when FMV_JOB_DRIVER=cloud_tasks
# FMV_BASE_URL=https://your-backend-service.run.app
# FMV_GCP_PROJECT=your-gcp-project-id
# FMV_CLOUD_TASKS_LOCATION=us-central1
# FMV_CLOUD_TASKS_QUEUE=fmv-pipeline

# Optional queue auth / hardening
# FMV_INTERNAL_TASK_TOKEN=replace_with_a_random_secret
# FMV_CLOUD_TASKS_SERVICE_ACCOUNT_EMAIL=cloud-tasks-invoker@your-gcp-project-id.iam.gserviceaccount.com
# FMV_CLOUD_TASKS_AUDIENCE=https://your-service.run.app/api/internal/projects
